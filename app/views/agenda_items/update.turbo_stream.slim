- if @old_list == @agenda_item.list
  = turbo_stream.replace "agenda_item_#{@agenda_item.id}",
                         partial: "agenda_items/item",
                         locals: { item: @agenda_item }
- else
  / List changed in the modal: move the row to the new list and refresh both counters.
  = turbo_stream.remove "agenda_item_#{@agenda_item.id}"
  = turbo_stream.append "agenda_items_list_#{@gathering.id}_#{@agenda_item.list}",
                         partial: "agenda_items/item",
                         locals: { item: @agenda_item }
  = turbo_stream.replace "agenda_items_empty_#{@gathering.id}_#{@agenda_item.list}",
                         partial: "agenda_items/empty_state",
                         locals: { gathering: @gathering, list: @agenda_item.list }
  = turbo_stream.replace "agenda_items_empty_#{@gathering.id}_#{@old_list}",
                         partial: "agenda_items/empty_state",
                         locals: { gathering: @gathering, list: @old_list }
  = turbo_stream.replace "agenda_items_counter_#{@gathering.id}_#{@old_list}",
                         partial: "agenda_items/counter",
                         locals: { gathering: @gathering, list: @old_list }

= turbo_stream.replace "agenda_items_counter_#{@gathering.id}_#{@agenda_item.list}",
                       partial: "agenda_items/counter",
                       locals: { gathering: @gathering, list: @agenda_item.list }
