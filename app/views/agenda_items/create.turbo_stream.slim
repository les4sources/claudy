= turbo_stream.append "agenda_items_list_#{@gathering.id}_#{@agenda_item.list}",
                       partial: "agenda_items/item",
                       locals: { item: @agenda_item }

= turbo_stream.replace "agenda_item_form_#{@gathering.id}_#{@agenda_item.list}",
                       partial: "agenda_items/inline_form",
                       locals: { gathering: @gathering, list: @agenda_item.list }

= turbo_stream.replace "agenda_items_empty_#{@gathering.id}_#{@agenda_item.list}",
                       partial: "agenda_items/empty_state",
                       locals: { gathering: @gathering, list: @agenda_item.list }

= turbo_stream.replace "agenda_items_counter_#{@gathering.id}_#{@agenda_item.list}",
                       partial: "agenda_items/counter",
                       locals: { gathering: @gathering, list: @agenda_item.list }
