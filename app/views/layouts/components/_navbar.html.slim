    .max-w-screen-xl.px-4.py-2.5.mx-auto
      .flex.items-center
        ul.flex.flex-row.font-medium.mt-0.gap-1.text-sm
          li
            = link_to "Tableau de bord",
                      dashboard_path,
                      class: "px-3 py-1.5 rounded-md transition-colors #{controller_name == 'pages' && action_name == 'dashboard' ? 'text-4s-main bg-teal-50 font-medium' : 'text-gray-500 hover:text-4s-main hover:bg-teal-50/60'}"
          li
            = link_to "Projets",
                      projects_path,
                      class: "px-3 py-1.5 rounded-md transition-colors #{controller_name == 'projects' ? 'text-4s-main bg-teal-50 font-medium' : 'text-gray-500 hover:text-4s-main hover:bg-teal-50/60'}"
          li
            = link_to "Pôles",
                      teams_path,
                      class: "px-3 py-1.5 rounded-md transition-colors #{controller_name == 'teams' ? 'text-4s-main bg-teal-50 font-medium' : 'text-gray-500 hover:text-4s-main hover:bg-teal-50/60'}"
          li
            = link_to "Actions",
                      tasks_path,
                      class: "px-3 py-1.5 rounded-md transition-colors #{controller_name == 'tasks' ? 'text-4s-main bg-teal-50 font-medium' : 'text-gray-500 hover:text-4s-main hover:bg-teal-50/60'}"

