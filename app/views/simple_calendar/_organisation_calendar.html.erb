<% @current_month = date_range.first.month %>
<div id="organisation-calendar" class="md:block lg:flex lg:h-full lg:flex-col bg-stone-100">
  <% first_week = date_range.first(7) %>
  <div class="calendar-weekdays-header hidden md:grid md:grid-cols-7 gap-px border-b border-stone-400/60 bg-stone-300 text-center text-[0.7rem] uppercase tracking-[0.14em] font-semibold leading-6 text-stone-700 lg:flex-none">
    <% first_week.each_with_index do |day, i| %>
      <div class="calendar-weekday relative flex items-center justify-center gap-1.5 py-2.5 <%= day.saturday? || day.sunday? ? "bg-slate-300 text-slate-800" : "bg-stone-200" %>">
        <span class="calendar-weekday__label"><%= l(day, format: "%A") %></span>
      </div>
    <% end %>
  </div>

  <div class="shadow ring-1 ring-black ring-opacity-5 lg:flex lg:flex-auto lg:flex-col">
    <% date_range.each_slice(7).with_index do |weekdays, index| %>
      <% if @cycles.present? %>
        <% week_start = weekdays.first; week_end = weekdays.last %>
        <% active_cycles = @cycles.select { |c| c.start_date <= week_end && c.end_date >= week_start } %>
        <% if active_cycles.any? %>
          <div class="flex items-center gap-2 px-3 py-1 bg-teal-50/80 border-b border-teal-100">
            <svg class="w-3 h-3 text-teal-400 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><polyline points="22 2 13 11 9 7"/></svg>
            <% active_cycles.each do |cycle| %>
              <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-teal-100/80 text-teal-700 border border-teal-200/60"><%= cycle.name %></span>
            <% end %>
          </div>
        <% end %>
      <% end %>

      <div class="week">
        <div class="flex bg-gray-200 text-xs leading-6 text-gray-700 lg:flex-auto">
          <div class="w-full lg:grid lg:grid-cols-7 lg:gap-px">
            <% weekdays.each do |day| %>
              <% is_current_month = (day.month == @date.month && day.year == @date.year) %>
              <% is_weekend = day.saturday? || day.sunday? %>
              <% background_class = if Date.today == day
                                      "bg-emerald-50 ring-1 ring-inset ring-emerald-200"
                                    elsif is_weekend
                                      is_current_month ? "bg-slate-100 ring-1 ring-inset ring-slate-200" : "bg-slate-100/60"
                                    elsif is_current_month
                                      "bg-white"
                                    else
                                      "bg-gray-50"
                                    end %>
              <% text_class = (is_current_month || is_weekend || Date.today == day) ? "text-gray-700" : "text-gray-400" %>
              <div class="calendar-day group relative min-h-[8rem] py-2 px-3 <%= background_class %> <%= text_class %>">
                <div class="flex place-content-between items-start">
                  <div>
                    <%= render partial: "simple_calendar/day", locals: { date: day } %>
                  </div>
                  <%= render partial: "pages/calendar/quick_create_button",
                             locals: { date: day, categories: @gathering_categories } %>
                </div>

                <%= turbo_frame_tag "day_gatherings_#{day.iso8601}", class: "block mt-1 space-y-1" do %>
                  <% @gatherings.select { |g| g.starts_at.to_date <= day && g.ends_at.to_date >= day }.each do |gathering| %>
                    <%= render partial: "pages/calendar/gathering",
                               locals: { gathering: gathering, date: day } %>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
